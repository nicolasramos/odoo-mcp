{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.nicolasramos/odooclaw-mcp",
  "description": "MCP server for Odoo 18 with 38 business tools",
  "repository": {
    "url": "https://github.com/nicolasramos/odooclaw-mcp.git",
    "source": "github"
  },
  "version": "2.1.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "odooclaw-mcp",
      "version": "2.1.0",
      "runtimeHint": "python",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "URL of your Odoo instance (e.g., https://yourcompany.odoo.com)",
          "isRequired": true,
          "isSecret": false,
          "name": "ODOO_URL"
        },
        {
          "description": "Name of your Odoo database",
          "isRequired": true,
          "isSecret": false,
          "name": "ODOO_DB"
        },
        {
          "description": "Odoo username for authentication",
          "isRequired": true,
          "isSecret": false,
          "name": "ODOO_USERNAME"
        },
        {
          "description": "Odoo password for authentication",
          "isRequired": true,
          "isSecret": true,
          "name": "ODOO_PASSWORD"
        },
        {
          "description": "Default limit for search results (default: 50)",
          "isRequired": false,
          "isSecret": false,
          "name": "ODOO_MCP_DEFAULT_LIMIT"
        },
        {
          "description": "Maximum limit for search results (default: 80)",
          "isRequired": false,
          "isSecret": false,
          "name": "ODOO_MCP_MAX_LIMIT"
        }
      ]
    }
  ]
}
